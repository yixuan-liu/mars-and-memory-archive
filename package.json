{
  "name": "@mars-memory-archive",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prisma:generate": "pnpm --filter @mars-memory-archive/api prisma:generate",
    "db:push": "pnpm --filter @mars-memory-archive/api db:push",
    "db:migrate": "pnpm --filter @mars-memory-archive/api db:migrate",
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter '@mars-memory-archive/shared' build && pnpm --parallel --filter './apps/*' build",
    "lint": "pnpm --recursive lint"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
