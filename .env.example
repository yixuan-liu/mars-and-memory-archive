# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mars_memory_archive"

# Qdrant
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="militaria_chunks"

# AI - OpenAI compatible (supports Doubao/Volcano Engine etc.)
